# NWN Modules Translator - Environment Configuration

# AI Provider API Key
# Get your API key from your chosen provider:
# - Grok (xAI):     https://console.x.ai/
# - OpenAI:         https://platform.openai.com/api-keys
# - Gemini:         https://aistudio.google.com/apikey
# - Mistral:        https://console.mistral.ai/api-keys/
# - OpenRouter:     https://openrouter.ai/keys  (keys start with sk-or-v1-…)
NWN_TRANSLATE_API_KEY=your_api_key_here

# Provider selection: grok | openai | gemini | mistral | openrouter
NWN_TRANSLATE_PROVIDER=openrouter

# Model override (optional, uses provider default if not set)
# OpenRouter model slugs: https://openrouter.ai/models
# Examples:
#   openai/gpt-oss-120b          (default)
#   anthropic/claude-3.5-sonnet
#   deepseek/deepseek-r1
#   google/gemini-2.0-flash-001
# NWN_TRANSLATE_MODEL=openai/gpt-oss-120b
