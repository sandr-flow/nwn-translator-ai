# NWN Modules Translator — copy to .env in the project directory

# OpenRouter API key (https://openrouter.ai/keys)
NWN_TRANSLATE_API_KEY=your_api_key_here

# Optional: model slug (default in code is google/gemini-3.1-flash-lite-preview)
# NWN_TRANSLATE_MODEL=google/gemini-3.1-flash-lite-preview

# Parallel OpenRouter requests (async coroutines, not OS threads). If unset, default is 12.
# Use 10–12 if you see HTTP 429; 15–20 is often fine on higher tiers / stable networks.
# NWN_TRANSLATE_MAX_CONCURRENT=12
